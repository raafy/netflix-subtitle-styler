{
  "manifest_version": 3,
  "name": "Netflix Subtitle Styler",
  "short_name": "SubStyler",
  "description": "Fully customize Netflix subtitles with presets and granular controls. Supports Crunchyroll-style, accessibility, cinema, and more.",
  "version": "1.0.0",
  "author": "raafy",
  "homepage_url": "https://github.com/raafy/netflix-subtitle-styler",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Netflix Subtitle Styler"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["content/content.js"],
      "css": [],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "*://*.netflix.com/*"
  ]
}
